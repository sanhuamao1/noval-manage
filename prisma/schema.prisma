generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./novel.db"
}

model Novel {
  id          String            @id @default(cuid())
  title       String
  description String?
  config      String            @default("{\"genre\":[\"玄幻\"],\"status\":\"连载中\"}")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  chapters    Chapter[]
  characters  Character[]
  outlines      Outline[]
  locations     Location[]
  foreshadowings Foreshadowing[]
}

model Chapter {
  id                String             @id @default(cuid())
  novelId           String
  novel             Novel              @relation(fields: [novelId], references: [id], onDelete: Cascade)
  title             String
  content           String
  status            String             @default("draft")  // draft: 草稿, published: 定稿
  relatedCharacters String?            // 关联人物ID列表，JSON数组格式 ["id1","id2"]
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  outline Outline?
}

model Character {
  id               String             @id @default(cuid())
  novelId          String
  novel            Novel              @relation(fields: [novelId], references: [id], onDelete: Cascade)
  name             String
  config           String             @default("{}")     // JSON - 包含所有角色特征数据
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  characterEmotions CharacterEmotion[]
}

model PolishRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  prompt      String
  config      String   @default("{}")
  type        String   @default("base")  // base: 基础规则, sample: 文风示例
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
}

// === 大纲 ===
// 与章节 1:1 关联，包含章纲的完整信息
model Outline {
  id            String    @id @default(cuid())
  novelId       String
  novel         Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterId     String?   @unique
  chapter       Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  title         String
  contentBrief  String?
  contentDetail String?
  status        String    @default("planned")  // planned / in_progress / completed
  sortOrder     Int       @default(0)
  config        String    @default("{}")  // JSON: { timeline, tone, characterIds[], locationIds[], foreshadowingIds[] }
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  characterEmotions CharacterEmotion[]
  keyEvents         KeyEvent[]
}

// === 人物情感/状态追踪 ===
// 记录人物在大纲中的情感状态（一条记录一个状态，多条表示连续变化）
model CharacterEmotion {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  outlineId   String
  outline     Outline   @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  emotion     String    // 情绪类型：喜悦/悲伤/愤怒/恐惧/惊讶/厌恶/爱/恨/焦虑/平静/...
  intensity   Int       @default(5)   // 情绪强度 1-10
  state       String?   // 人物状态/处境描述
  description String?   // 具体场景描述或触发原因
  createdAt   DateTime  @default(now())
}

// === 地点 ===
// 作品中的地点/场景，与 novel 关联，大纲中通过 locationIds 引用
model Location {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// === 伏笔 ===
// 作品中的伏笔，与 novel 关联，大纲中通过 foreshadowingIds 引用
model Foreshadowing {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// === 关键事件 ===
// 绑定到具体大纲
model KeyEvent {
  id        String   @id @default(cuid())
  outlineId String
  outline   Outline  @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
