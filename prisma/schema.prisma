generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── 小说 ──
model Novel {
  id            String   @id
  title         String
  description   String?
  status        String   @default("连载中")
  genre         String?  // JSON: string[]
  primaryTone   String?
  secondaryTones String? // JSON: string[]
  worldShape    String?
  presetStyle   String?
  oneLineSummary String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chapters         Chapter[]
  characters       Character[]
  outlines         Outline[]
  locations        Location[]
  organizations    Organization[]
  eventNodes        EventNode[]
  eventConnections  EventConnection[]
  outlineEvents     OutlineEvent[]
  relations        Relation[]
  nodePositions    NodePosition[]
  conversations    FactoryConversation[]
}

// ── 角色 ──
model Character {
  id                String   @id
  novelId           String
  name              String   @default("")
  gender            String?
  role              String?
  age               String?
  identity          String?
  item              String?
  coreConflict      String?
  surfaceGoal       String?
  deepNeed          String?
  emotionExpression String?
  abilities         String?  // JSON: string[]
  growthArcs        String?  // JSON: array of {缺陷, 表现, 成长方向}
  notes             String?  // JSON: array of {标签, 内容}
  experience        String?  // JSON: array of {经历描述}
  narrativeFunction String?  // JSON: string[]
  innerMotivation   String?  // JSON: string[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  novel            Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  sourceRelations  Relation[] @relation("sourceRelations")
  targetRelations  Relation[] @relation("targetRelations")
}

// ── 大纲（parentId 构成单向链表，根节点 parentId = null）──
model Outline {
  id              String   @id
  novelId         String
  parentId        String?
  name            String   @default("")
  contentBrief    String?
  contentDetail   String?
  status          String   @default("已规划")
  tone            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  novel      Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  parent     Outline?       @relation("OutlineHierarchy", fields: [parentId], references: [id])
  children   Outline[]      @relation("OutlineHierarchy")
  chapters   Chapter[]
  eventLinks OutlineEvent[]

  @@index([novelId])
  @@index([parentId])
}

// ── 章节 ──
model Chapter {
  id                String   @id
  novelId           String
  outlineId         String?  // 关联大纲
  title             String   @default("")
  content           String   @default("")
  status            String   @default("draft")
  sortOrder         Int      @default(0)
  relatedCharacters String?  // JSON: string[] 或 null
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  novel   Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  outline Outline? @relation(fields: [outlineId], references: [id])

  @@index([novelId])
}

// ── 地点 ──
model Location {
  id           String   @id
  novelId      String
  name         String   @default("")
  description  String?
  locationType String?  // JSON: string[]
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

// ── 组织 ──
model Organization {
  id                String   @id
  novelId           String
  name              String   @default("")
  description       String?
  type              String?  // JSON: string[]
  status            String?
  foundingBackground String?
  founder           String?
  currentLeader     String?
  operationLogic    String?
  structure         String?  // JSON: array of {等级, 作用/职责}
  headquarters      String?  // JSON: string[]
  members           String?  // JSON: array of {代号, 等级, 备注}
  opponents         String?  // JSON: string[]
  mortalEnemies     String?  // JSON: string[]
  allies            String?  // JSON: string[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

// ── 事件节点（故事世界中的具体事件） ──
model EventNode {
  id          String   @id
  novelId     String
  title       String   @default("")
  description String?  // 事件简述
  content     String?  // 详细描写（富文本）

  storyTime   String?  // 故事内时间

  // 直接中文值，选项来自 shared-options.yml event-type
  eventType   String?  // 关键剧情 / 日常 / 转折 / 战斗 / 感情 / 伏笔揭示
  // 直接中文值，选项来自 shared-options.yml event-status
  status      String   @default("已规划")
  importance  Int      @default(1)  // 1-5

  // 关联现有实体
  characterIds      String?  // JSON: string[]
  locationIds       String?  // JSON: string[]

  notes       String?  // JSON: 额外元数据

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  // 事件间关系链
  outgoing EventConnection[] @relation("EventConnectionSource")
  incoming EventConnection[] @relation("EventConnectionTarget")
  // 大纲关联
  outlineLinks OutlineEvent[]

  @@index([novelId])
}

// ── 事件间关系 ──
model EventConnection {
  id        String   @id
  novelId   String
  sourceId  String
  targetId  String
  type      String   @default("导致")  // 导致 / 铺垫揭示 / 平行对照 / 对比
  strength  Int      @default(1)       // 1-3
  createdAt DateTime @default(now())

  novel  Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  source EventNode @relation("EventConnectionSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target EventNode @relation("EventConnectionTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([novelId])
  @@index([sourceId])
  @@index([targetId])
}

// ── 大纲与事件的多对多关联（带排序） ──
model OutlineEvent {
  id         String @id
  novelId    String
  outlineId  String
  eventId    String
  sortOrder  Int    @default(0)  // 事件在大纲中的顺序

  novel   Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  outline Outline  @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  event   EventNode @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([outlineId, eventId])
  @@index([novelId])
  @@index([outlineId])
  @@index([eventId])
}

// ── 角色关系（从 relations.yml 拆分） ──
model Relation {
  id          String   @id
  novelId     String
  sourceId    String
  targetId    String
  description String   @default("")
  createdAt   DateTime @default(now())

  novel  Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  source Character @relation("sourceRelations", fields: [sourceId], references: [id])
  target Character @relation("targetRelations", fields: [targetId], references: [id])

  @@index([novelId])
  @@index([sourceId])
  @@index([targetId])
}

// ── 节点位置（从 relations.yml 拆分） ──
model NodePosition {
  id        String   @id
  novelId   String
  charId    String
  x         Float    @default(0)
  y         Float    @default(0)
  createdAt DateTime @default(now())

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, charId])
  @@index([novelId])
}

// ── 润色规则（全局实体） ──
model PolishRule {
  id                String   @id
  name              String   @default("")
  description       String?
  prompt            String?
  pace              String?
  mood              String?  // JSON: string[]
  narrative         String?
  senses            String?  // JSON: string[]
  character         String?  // JSON: string[]
  environment       String?  // JSON: string[]
  rhetoric          String?
  timeVariation     Boolean  @default(false)
  contrastInsertion Boolean  @default(false)
  useCount          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── 风格样本（全局实体） ──
model PolishSample {
  id         String   @id
  name       String   @default("")
  prompt     String?
  sceneType  String?
  text       String?
  isNegative Boolean  @default(false)
  useCount   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── 大纲框架（全局实体） ──
model Framework {
  id        String   @id
  name      String   @default("")
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 梦工厂对话会话 ──
model FactoryConversation {
  id        String   @id
  novelId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  novel    Novel            @relation(fields: [novelId], references: [id], onDelete: Cascade)
  messages FactoryMessage[]

  @@index([novelId])
}

// ── 梦工厂对话消息 ──
model FactoryMessage {
  id             String   @id
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  conversation FactoryConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
